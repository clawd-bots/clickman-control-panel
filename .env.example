# Copy to .env.local and fill in values.

# Supabase (Dashboard → Project Settings → API)
# Server routes use the service role key. URL must be one of:
#   NEXT_PUBLIC_SUPABASE_URL (recommended for Next.js)
#   PUBLIC_SUPABASE_URL or SUPABASE_URL (aliases also work in this app)
# Anon key is optional until you use Supabase from the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Other integrations (see existing .env.local)
